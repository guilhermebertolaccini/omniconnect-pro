# =============================================================================
# OmniconnectPRO — Staging environment (Sprint Hub / PR 6).
#
# Copy to `.env.staging` and fill values. NEVER commit `.env.staging`.
#
# Two usage modes:
#   1) Local mirror — `docker compose --env-file .env.staging -f docker-compose.staging.yml up -d`
#   2) Coolify — paste these values into each application's env panel
#      (`omniconnect-backend`, `omniconnect-hub`, `omniconnect-frontend`,
#      `crm-imobiliario`, `smart-ad-automator`, `botify`). Coolify lets you
#      share env via teams/projects — do that, don't paste twice.
#
# Authority: ADR-0003 (identity + cookie domain), ADR-0004 (module gateway),
# docs/04-security.md (secrets handling), docs/deployment/coolify-staging.md
# (runbook).
# =============================================================================

# ─── Domains (Coolify staging) ─────────────────────────────────────────────
# All apps live under the same parent domain so the refresh cookie
# (`Domain=.staging.omniconnectpro.<example>`) works across them.
STAGING_PARENT_DOMAIN=staging.omniconnectpro.example.com
APP_URL=https://app.${STAGING_PARENT_DOMAIN}

# ─── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_USER=omni
POSTGRES_PASSWORD=
POSTGRES_DB=omniconnect
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_PORT=6379
# In Coolify, point REDIS_HOST at the managed Redis service.

# ─── Auth / Cookies (ADR-0003) ────────────────────────────────────────────
# JWT secret: random ≥32 chars. `openssl rand -hex 32`.
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS origins — comma-separated list of every frontend domain that calls
# the backend. NEVER `*` in production.
CORS_ORIGINS=https://app.${STAGING_PARENT_DOMAIN},https://omni.${STAGING_PARENT_DOMAIN},https://crm.${STAGING_PARENT_DOMAIN},https://ads.${STAGING_PARENT_DOMAIN},https://botify.${STAGING_PARENT_DOMAIN}

# Cookie domain: dot-prefixed parent so refresh works across subdomains.
COOKIE_DOMAIN=.${STAGING_PARENT_DOMAIN}
COOKIE_SECURE=true

# Allow `POST /auth/register` (Sprint 2.4 B.3). Keep `false` unless intentionally
# enabling self-service tenant signup.
ALLOW_PUBLIC_TENANT_SIGNUP=false

# ─── Encryption at rest (Sprint 1.3 / 2.3) ─────────────────────────────────
# AES-256-GCM master key for `BridgeSecretCipher`. Format: 32 bytes base64
# (preferred) or 64-char hex. `openssl rand -base64 32`.
BRIDGE_SECRET_KEY=

# ─── InsightAI (docs/05-ai-governance.md) ──────────────────────────────────
# Empty `OPENAI_API_KEY` → heuristic fallback (still useful for staging
# without burning real LLM cost).
INSIGHT_AI_DEFAULT_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional alternatives:
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Pilot §4.1 — enqueue analysis on Botify handoff.
INSIGHT_AI_ON_BOTIFY_HANDOFF=true

# ─── Botify (ADR-0001 / ADR-0002) ──────────────────────────────────────────
# Shared between backend (`/botify/internal/...`) and the microservice. Same
# value in both. `openssl rand -hex 32`.
BOTIFY_INTERNAL_SYNC_SECRET=

# ─── Meta / WhatsApp (PR 7 — preencher antes da validação real) ────────────
# Estes campos vêm do app Meta Developer de staging. Antes da PR 7 ficam vazios.
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=

# ─── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info                   # debug | info | warn | error

# ─── Compose image tags (local mirror only) ────────────────────────────────
BACKEND_IMAGE=omniconnect/backend:staging
HUB_IMAGE=omniconnect/hub:staging
OMNI_FRONTEND_IMAGE=omniconnect/omniconnect-frontend:staging
CRM_IMAGE=omniconnect/crm-imobiliario:staging
SAA_IMAGE=omniconnect/smart-ad-automator:staging
BOTIFY_IMAGE=omniconnect/botify:staging

# ─── Compose port mappings (local mirror only) ─────────────────────────────
BACKEND_PORT=3000
HUB_PORT=4173
OMNI_FRONTEND_PORT=8080
CRM_PORT=8081
SAA_PORT=8082
BOTIFY_PORT=8083

# ─── Frontends (Vite — baked at build time) ────────────────────────────────
# In Coolify these are SET ON THE APP, not the backend. The values below are
# used by docker-compose for local mirror; for Coolify each app passes its own
# VITE_API_URL via build env.
VITE_API_URL=https://api.${STAGING_PARENT_DOMAIN}
VITE_USE_MOCK_AUTH=false
VITE_USE_MOCK_DATA=false
VITE_CRM_URL=https://crm.${STAGING_PARENT_DOMAIN}
VITE_OMNIHUB_URL=https://omni.${STAGING_PARENT_DOMAIN}
VITE_SAA_URL=https://ads.${STAGING_PARENT_DOMAIN}
VITE_BOTIFY_URL=https://botify.${STAGING_PARENT_DOMAIN}
