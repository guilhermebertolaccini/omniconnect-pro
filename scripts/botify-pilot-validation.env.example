# Copie para scripts/botify-pilot-validation.env (não commitar) e ajuste:
#   cp scripts/botify-pilot-validation.env.example scripts/botify-pilot-validation.env
#
# O script também lê variáveis já exportadas no shell.

# --- Omni backend ---
OMNICONNECT_BACKEND_URL=http://localhost:3000
OMNICONNECT_TENANT_ID=default-tenant

# Login JWT (omitir BOTIFY_JWT_TOKEN para usar email/senha).
# Defina uma senha local segura via SEED_ADMIN_PASSWORD antes de criar o seed.
OMNICONNECT_LOGIN_EMAIL=admin@vend.com
OMNICONNECT_LOGIN_PASSWORD=

# Ou token pronto (ex.: copiado do DevTools após login no Botify/Omni)
# BOTIFY_JWT_TOKEN=

# Mesmo valor em apps/omniconnect-backend/.env e microservice/.env.
# Se /health mostra botifyInternalSync.configured=true mas este script avisa
# "não definido", copie aqui o valor do env usado pelo backend em execução.
BOTIFY_INTERNAL_SYNC_SECRET=

# --- Handoff Botify -> Omni (scripts/botify-handoff-validation.sh) ---
# Em staging/prod deve ser um segredo próprio do webhook HMAC Botify.
# Em dev, se vazio, o script usa BOTIFY_INTERNAL_SYNC_SECRET como fallback.
# OMNICONNECT_BOT_BRIDGE_WEBHOOK_SECRET=
# Opcional: força uma IntegrationConnection existente provider=bot.
# OMNICONNECT_BOT_BRIDGE_CONNECTION_ID=
# BOTIFY_HANDOFF_PHONE=+5511999990001

# --- Meta webhook simulado (scripts/botify-meta-webhook-validation.sh) ---
# BOTIFY_META_APP_SECRET=dev-meta-app-secret
# BOTIFY_META_PHONE=5511999990002
# BOTIFY_META_PREFIX=pilot-meta

# --- Microserviço (opcional; passos 9–10) ---
BOTIFY_MICROSERVICE_URL=http://localhost:3001

# IDs usados no smoke de routing (não precisam ser reais na Meta)
BOTIFY_PILOT_WABA_ID=pilot-waba-dev
BOTIFY_PILOT_PHONE_NUMBER_ID=000000000000000

# Prefixo dos recursos criados (bot/fluxo/conta Meta)
BOTIFY_PILOT_PREFIX=pilot

# 1 = apagar bot/fluxo/conta criados no fim (se o script os criou)
# BOTIFY_PILOT_CLEANUP=0

# 1 = não rodar prisma migrate deploy
# BOTIFY_SKIP_MIGRATE=0

# 1 = só health + internal (sem criar dados; use IDs existentes abaixo)
# BOTIFY_SKIP_CREATE=0
# BOTIFY_EXISTING_FLOW_ID=
# BOTIFY_EXISTING_WABA_ID=
