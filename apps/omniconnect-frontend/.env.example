VITE_API_URL=http://localhost:3000
# Em publicação, a API emite o cookie HttpOnly host-only e este app restaura
# a sessão com credentials; nunca configure token Vite para autenticação.

# Mock Data - Ativar dados mockados para apresentação aos clientes
# true = usa dados mockados | false = usa dados reais da API
VITE_USE_MOCK_DATA=false
