# =============================================================================
# OmniconnectPRO — Hub (app shell) environment variables
# Copy to .env and fill values. NEVER commit .env.
#
# Authority: ADR-0003 (identity → backend Omni) + ADR-0004 (Module Gateway).
# =============================================================================

# ---- Backend (canonical identity per ADR-0003) ----

# Base URL of omniconnect-backend (no trailing slash).
VITE_API_URL=http://localhost:3000

# ---- Module Gateway (ADR-0004 §4) ----
# Each domain app lives at its own URL. The Hub navigates to these
# via `ModulePlaceholder` (no JWT in querystring).

VITE_CRM_URL=http://localhost:5174
VITE_OMNIHUB_URL=http://localhost:5173
VITE_SAA_URL=http://localhost:5175
VITE_BOTIFY_URL=http://localhost:5176

# ---- App metadata ----

VITE_APP_NAME=OmniconnectPRO

# ---- Mock / preview mode (ADR-0003 §5) ----
# When true, the Hub uses the legacy Supabase Auth path bundled from the
# Lovable preview. NEVER set to true in staging/production.
VITE_USE_MOCK_AUTH=false
VITE_USE_MOCK_DATA=true

# ---- Supabase legacy (only used when VITE_USE_MOCK_AUTH=true) ----
# Anon/publishable keys are safe to expose; service-role keys are NOT.
# Keep blank in production deploys.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
