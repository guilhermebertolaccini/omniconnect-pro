# Server Configuration
PORT=3001
NODE_ENV=development

# WordPress Backend (obrigatório se BOTIFY_FLOW_SOURCE=wordpress ou dual)
# WORDPRESS_API_URL=https://your-wordpress-site.com
# WORDPRESS_API_KEY=your-32-character-or-longer-api-key

# Security
JWT_SECRET=your-32-character-or-longer-jwt-secret
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8090,https://your-frontend.com

# AI Providers (at least one required)
LOVABLE_API_KEY=your-lovable-api-key
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key

# Redis (required for BullMQ message queue - use internal hostname in Coolify)
# Local: redis://localhost:6379
# Coolify: redis://<redis-service-hostname>:6379
REDIS_URL=redis://localhost:6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# OmniconnectPRO bridge (opcional — handoff humano na fila de mensagens)
# Piloto: 1 instalação = 1 IntegrationConnection (provider bot) — ver docs/adr/ADR-0001-botify-tenancy-model.md
# Use o mesmo segredo em texto que a `IntegrationConnection` (provider bot) no Omni backend.
# OMNICONNECT_API_URL=https://api.seu-dominio.com
# OMNICONNECT_BOT_BRIDGE_CONNECTION_ID=
# OMNICONNECT_BOT_BRIDGE_WEBHOOK_SECRET=

# Fonte do grafo em runtime (ADR-0002 G4): wordpress | omniconnect | dual
# BOTIFY_FLOW_SOURCE=wordpress
# OMNICONNECT_BACKEND_URL=https://api.example.com
# BOTIFY_INTERNAL_SYNC_SECRET= # mesmo segredo que BOTIFY_INTERNAL_SYNC_SECRET no omniconnect-backend
# OMNICONNECT_BOTIFY_TENANT_ID= # UUID do tenant no Omni

# Meta webhooks (G7 — sem WordPress)
# META_APP_SECRET=
# META_WEBHOOK_VERIFY_TOKEN=

# Fallback routing piloto (se PATCH channel não tiver mapping)
# BOTIFY_DEFAULT_BOT_ID=
# BOTIFY_DEFAULT_FLOW_ID=
