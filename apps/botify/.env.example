# ============================================
# BotFlow Manager - Frontend Environment
# ============================================
# Copie este arquivo para .env e configure os valores
# Servidor dev Vite usa porta 8090 (vite.config.ts) — incluir em CORS do omniconnect-backend se chamar API direta no browser.

# URL da REST API do WordPress
# Exemplo: http://localhost/meu-site/wp-json
VITE_WORDPRESS_API_URL=http://localhost/seu-wordpress/wp-json

# Auth (E1): omniconnect (JWT Omni) | wordpress (legado plugin)
VITE_BOTIFY_AUTH_SOURCE=omniconnect

# Fonte de bots/fluxos (ADR-0002 G5): wordpress | omniconnect | dual
VITE_BOTIFY_DATA_SOURCE=omniconnect

# Omniconnect backend — dev usa proxy Vite /api → :3000
VITE_OMNICONNECT_API_URL=/api
# VITE_OMNICONNECT_API_TOKEN=  # só CI/scripts; preferir login no browser

# URL do Microserviço Node.js
VITE_MICROSERVICE_URL=http://localhost:3001
