# Copie este arquivo para .env e configure os valores

# URL da REST API do WordPress
# Exemplo: http://localhost/meu-site/wp-json
VITE_WORDPRESS_API_URL=http://localhost/seu-wordpress/wp-json

# URL do Microserviço Node.js
VITE_MICROSERVICE_URL=http://localhost:3001
