# Database
# Exemplo legado / outro compose: ajustar user, password e nome da BD.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vend?schema=public"
# Monorepo — `docker-compose.yml` na raiz (`user=dev`, `password=dev`, DB `omniconnect`):
# DATABASE_URL="postgresql://dev:dev@localhost:5432/omniconnect?schema=public"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_USERNAME=""
REDIS_DB=0

# JWT
JWT_SECRET="dev-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV=development
APP_URL="http://localhost:3000"

# CORS (incluir origem do Vite Botify — porta padrão 8090 em apps/botify/vite.config.ts)
CORS_ORIGINS="http://localhost:5173,http://localhost:3001,http://localhost:8090"

# Meta WhatsApp Cloud API
META_WEBHOOK_TOKEN="seu-webhook-token-aqui"
META_APP_SECRET="seu-app-secret-aqui"

# Archiving
ARCHIVE_AFTER_DAYS=90

# InsightAI — após handoff Botify, enfileira análise por telefone (default off; custo LLM)
# INSIGHT_AI_ON_BOTIFY_HANDOFF=false

# Botify — leitura interna de fluxos pelo microserviço (ADR-0002 G4)
# Segredo partilhado com apps/botify microservice: Authorization Bearer + header X-Omni-Tenant-Id
# BOTIFY_INTERNAL_SYNC_SECRET="min-32-chars-dev-only-change-in-prod"
