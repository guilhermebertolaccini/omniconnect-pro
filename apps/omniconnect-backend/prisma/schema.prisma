generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum Role {
  admin
  operator
  supervisor
  ativador
  digital
  broker
}

enum Status {
  Online
  Offline
}

enum LineStatus {
  active
  ban
}

enum Sender {
  operator
  contact
}

enum Speed {
  fast
  medium
  slow
}

// External ad platforms supported by the SAA (Smart Ad Automator) domain.
// Mirrors Supabase enum `ad_platform`. Add new providers here (e.g.
// `linkedin_ads`) before referencing them from AdPlatformConnection.
enum AdPlatform {
  meta
  google_ads
  tiktok_ads
}

// -----------------------------------------------------------------------
// CRM Imobiliário enums (Sprint 3). Mirror dos enums Supabase originais
// do crm-imobiliario, normalizados ao snake_case do Postgres já em uso.
// -----------------------------------------------------------------------
enum CrmUnitStatus {
  available
  reserved
  sold
}

enum CrmClientScore {
  A
  B
  C
  D
}

enum CrmLeadStage {
  new
  contacted
  qualified
  proposal
  negotiation
  visit
  won
  lost
  closed_won
  closed_lost
}

enum CrmInteractionType {
  call
  email
  whatsapp
  meeting
  note
  visit
}

enum CrmProposalStatus {
  draft
  sent
  accepted
  rejected
}

enum CrmContractStatus {
  draft
  review
  pending_signature
  signed
}

enum CrmPaymentType {
  signal
  installment
  balloon
}

enum CrmPaymentStatus {
  pending
  paid
  overdue
}

enum CrmCommissionStatus {
  pending
  paid
}

enum CrmDocumentParentType {
  proposal
  contract
}

enum CrmDocumentVersionAction {
  attached
  replaced
  generated
  imported
}

enum CrmDocumentAccessAction {
  viewed
  downloaded
}

// Models
model User {
  id             Int      @id @default(autoincrement())
  name           String
  email          String   @unique
  password       String
  role           Role
  segment        Int?
  line           Int? // Mantido para compatibilidade (deprecated - usar LineOperators)
  status         Status   @default(Offline)
  oneToOneActive Boolean  @default(true) // Se true, operador pode chamar clientes no 1x1
  isActive       Boolean  @default(true) // Se false, operador está desativado
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lineOperators LineOperator[] // Relacionamento com linhas
  createdLines  LinesStock[] // Linhas criadas por este usuário (para ativadores)

  systemEvents  SystemEvent[]
  tenants       UserTenant[]
  apiKeys       TenantApiKey[]
  refreshTokens RefreshToken[]

  // Smart Ad Automator (SAA) relations
  invitedTenantInvitations      TenantInvitation[]        @relation("TenantInvitationInvitedBy")
  acceptedTenantInvitations     TenantInvitation[]        @relation("TenantInvitationAcceptedBy")
  createdAdvertiserCompanies    AdvertiserCompany[]       @relation("AdvertiserCompanyCreatedBy")
  advertiserCompanyAccesses     AdvertiserCompanyAccess[]
  createdAdPlatformConnections  AdPlatformConnection[]    @relation("AdPlatformConnectionCreatedBy")
  generatedAdCampaignAIAnalyses AdCampaignAIAnalysis[]    @relation("AdCampaignAIAnalysisGeneratedBy")
  createdOrganicPostExperiments OrganicPostExperiment[]   @relation("OrganicPostExperimentCreatedBy")

  // CRM Imobiliário (Sprint 3) — User só aparece nas pontas que importam:
  // (a) corretor responsável (broker), (b) criador/autor de evento.
  crmPropertiesCreated   CrmProperty[]               @relation("CrmPropertyCreatedBy")
  crmClientsAsBroker     CrmClient[]                 @relation("CrmClientBroker")
  crmLeadsAsBroker       CrmLead[]                   @relation("CrmLeadBroker")
  crmInteractionsCreated CrmInteraction[]            @relation("CrmInteractionCreatedBy")
  crmFollowUpsCreated    CrmFollowUp[]               @relation("CrmFollowUpCreatedBy")
  crmProposalsAsBroker   CrmProposal[]               @relation("CrmProposalBroker")
  crmContractsAsBroker   CrmContract[]               @relation("CrmContractBroker")
  crmCommissionsAsBroker CrmCommission[]             @relation("CrmCommissionBroker")
  crmNotificationPrefs   CrmNotificationPreference[]

  @@index([email])
  @@index([segment])
  @@index([line])
  @@index([role, status])
}

model Segment {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenantId  String   @default("default-tenant")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@index([name])
  @@index([tenantId])
}

model Tabulation {
  id         Int      @id @default(autoincrement())
  name       String
  isCPC      Boolean  @default(false)
  isEnvio    Boolean  @default(true)
  isEntregue Boolean  @default(true)
  isLido     Boolean  @default(true)
  isRetorno  Boolean  @default(true)
  isCPCProd  Boolean  @default(false)
  isBoleto   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenantId   String   @default("default-tenant")
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@index([name])
  @@index([tenantId])
}

model Contact {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String // Telefone único - não permite duplicados
  segment   Int?
  cpf       String?
  contract  String?
  isCPC     Boolean   @default(false) // Se true, contato foi marcado como CPC
  lastCPCAt DateTime? // Última vez que foi marcado como CPC (para temporizador)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tenantId  String    @default("default-tenant")
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, phone])
  @@index([phone])
  @@index([cpf])
  @@index([segment])
  @@index([isCPC])
  @@index([tenantId])
}

model Campaign {
  id                Int       @id @default(autoincrement())
  name              String
  contactName       String
  contactPhone      String
  contactSegment    Int?
  dateTime          DateTime  @default(now())
  lineReceptor      Int?
  response          Boolean   @default(false)
  speed             Speed
  retryCount        Int       @default(0)
  useTemplate       Boolean   @default(false)
  templateId        Int?
  templateVariables String?   @db.Text
  endTime           DateTime? // Horário limite para envio das mensagens
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  tenantId          String    @default("default-tenant")
  tenant            Tenant    @relation(fields: [tenantId], references: [id])

  @@index([contactPhone])
  @@index([contactSegment])
  @@index([lineReceptor])
  @@index([response])
  @@index([dateTime])
  @@index([templateId])
  @@index([name])
  @@index([tenantId])
}

model BlockList {
  id        Int      @id @default(autoincrement())
  name      String?
  phone     String?
  cpf       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenantId  String   @default("default-tenant")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([phone])
  @@index([cpf])
  @@index([tenantId])
}

// App Meta (WhatsApp Business App)
model App {
  id                 Int      @id @default(autoincrement())
  name               String
  accessToken        String // Token de acesso do WhatsApp Cloud API
  appSecret          String? // App Secret para validação de assinatura do webhook
  webhookVerifyToken String? // Token de verificação do webhook
  wabaId             String? // WhatsApp Business Account ID (opcional)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tenantId           String   @default("default-tenant")
  tenant             Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@index([name])
  @@index([tenantId])
}

model LinesStock {
  id           Int        @id @default(autoincrement())
  phone        String
  lineStatus   LineStatus @default(active)
  segment      Int?
  linkedTo     Int? // Mantido para compatibilidade (deprecated - usar LineOperators)
  oficial      Boolean    @default(true) // Todas as linhas são oficiais (Cloud API)
  appId        Int // ID do App (credenciais vêm do App)
  numberId     String // Phone Number ID (obrigatório)
  receiveMedia Boolean    @default(false) // Se true, baixa mídia automaticamente
  createdBy    Int? // ID do usuário que criou a linha (para rastrear produtividade dos ativadores)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  operators LineOperator[] // Relacionamento com operadores
  creator   User?          @relation(fields: [createdBy], references: [id]) // Usuário que criou
  templates Template[] // Templates vinculados a esta linha
  tenantId  String         @default("default-tenant")
  tenant    Tenant         @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, phone])
  @@index([phone])
  @@index([lineStatus])
  @@index([segment])
  @@index([linkedTo])
  @@index([numberId])
  @@index([createdBy])
  @@index([appId])
  @@index([tenantId])
}

// Tabela de relacionamento entre Linhas e Operadores (máximo 2 operadores por linha)
model LineOperator {
  id        Int      @id @default(autoincrement())
  lineId    Int
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  line     LinesStock @relation(fields: [lineId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId String     @default("default-tenant")
  tenant   Tenant     @relation(fields: [tenantId], references: [id])

  @@unique([lineId, userId])
  @@index([lineId])
  @@index([userId])
  @@index([tenantId])
}

model Conversation {
  id           Int       @id @default(autoincrement())
  contactName  String
  contactPhone String
  segment      Int?
  userName     String?
  userLine     Int? // ID da linha (mantido para compatibilidade)
  userId       Int? // ID do operador específico que está atendendo
  message      String    @db.Text
  sender       Sender
  datetime     DateTime  @default(now())
  tabulation   Int?
  messageType  String    @default("text")
  mediaUrl     String?
  messageId    String? // WhatsApp Message ID (wamid) - usado para evitar duplicatas
  archived     Boolean   @default(false) // Se true, conversa foi arquivada
  archivedAt   DateTime? // Data de arquivamento
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tenantId     String    @default("default-tenant")
  tenant       Tenant    @relation(fields: [tenantId], references: [id])

  @@index([contactPhone])
  @@index([segment])
  @@index([userLine])
  @@index([userId])
  @@index([tabulation])
  @@index([datetime])
  @@index([archived, datetime])
  @@index([archivedAt])
  @@index([messageId])
  @@index([tenantId])
}

model Tag {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  segment     Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenantId    String   @default("default-tenant")
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@index([name])
  @@index([segment])
  @@index([tenantId])
}

model ApiLog {
  id              Int      @id @default(autoincrement())
  endpoint        String
  method          String
  requestPayload  String   @db.Text
  responsePayload String   @db.Text
  statusCode      Int
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())
  tenantId        String   @default("default-tenant")
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([endpoint])
  @@index([method])
  @@index([statusCode])
  @@index([createdAt])
  @@index([tenantId])
}

// Template para mensagens de campanha (vinculado a segmento)
model Template {
  id            Int         @id @default(autoincrement())
  name          String
  language      String      @default("pt_BR")
  category      String      @default("MARKETING")
  segmentId     Int? // null = global (todos os segmentos)
  lineId        Int? // Template vinculado a uma linha específica
  line          LinesStock? @relation(fields: [lineId], references: [id])
  namespace     String?
  status        String      @default("APPROVED")
  headerType    String?
  headerContent String?     @db.Text
  bodyText      String      @db.Text
  footerText    String?
  buttons       String?     @db.Text
  variables     String?     @db.Text
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  tenantId      String      @default("default-tenant")
  tenant        Tenant      @relation(fields: [tenantId], references: [id])

  @@index([name])
  @@index([segmentId])
  @@index([status])
  @@index([category])
  @@index([tenantId])
}

// Histórico de envios de templates
model TemplateMessage {
  id           Int      @id @default(autoincrement())
  templateId   Int
  contactPhone String
  contactName  String?
  lineId       Int
  status       String   @default("SENT")
  messageId    String?
  variables    String?  @db.Text
  errorMessage String?
  campaignId   Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenantId     String   @default("default-tenant")
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@index([templateId])
  @@index([contactPhone])
  @@index([lineId])
  @@index([status])
  @@index([campaignId])
  @@index([createdAt])
  @@index([tenantId])
}

// Painel de Controle - Configurações globais do sistema
model ControlPanel {
  id        Int  @id @default(autoincrement())
  segmentId Int? // null = global (todos os segmentos)

  // Frases de bloqueio automático (JSON array de strings)
  blockPhrasesEnabled Boolean @default(true) // Ativar/desativar frases de bloqueio
  blockPhrases        String? @db.Text
  blockTabulationId   Int? // Tabulação padrão ao bloquear

  // Temporizador de CPC (em horas)
  cpcCooldownEnabled Boolean @default(true) // Ativar/desativar temporizador de CPC
  cpcCooldownHours   Int     @default(24)

  // Reenvio - Intervalo mínimo entre campanhas para o mesmo telefone (em horas)
  resendCooldownEnabled Boolean @default(true) // Ativar/desativar controle de reenvio
  resendCooldownHours   Int     @default(24)

  // Repescagem - Controle de mensagens seguidas do operador
  repescagemEnabled       Boolean @default(false)
  repescagemMaxMessages   Int     @default(2) // Quantas msgs seguidas antes de bloquear
  repescagemCooldownHours Int     @default(24) // Tempo de espera após bloqueio
  repescagemMaxAttempts   Int     @default(2) // Limite de repescagens (0 = ilimitado)

  // Linhas ativas - Controla quais linhas podem ser usadas para atribuição (deprecated, manter para compatibilidade)
  activeLines String? @db.Text // JSON array de IDs de linhas (null = todas ativas)

  // Mensagem automática quando cliente não responde
  autoMessageEnabled     Boolean @default(false) // Ativar/desativar mensagem automática (desativado por padrão)
  autoMessageHours       Int     @default(24) // Quantas horas sem resposta antes de enviar mensagem
  autoMessageText        String? @db.Text // Texto da mensagem automática (ex: "Oi, ainda está aí?")
  autoMessageMaxAttempts Int     @default(1) // Quantas vezes enviar a mensagem (padrão 1)

  // Filtro de conversas - Quantos dias de conversas aparecem no frontend
  conversationFilterDays Int @default(3) // Conversas com mais de X dias são removidas do frontend (padrão: 3 dias)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenantId  String   @default("default-tenant")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, segmentId])
  @@index([segmentId])
  @@index([tenantId])
}

// Histórico de repescagem por contato
model ContactRepescagem {
  id             Int       @id @default(autoincrement())
  contactPhone   String
  operatorId     Int
  messagesCount  Int       @default(0) // Contagem de msgs seguidas do operador
  attempts       Int       @default(0) // Quantidade de repescagens realizadas
  blockedUntil   DateTime? // Bloqueado até essa data
  permanentBlock Boolean   @default(false) // Se true, só libera se cliente responder
  lastMessageAt  DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  tenantId       String    @default("default-tenant")
  tenant         Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([contactPhone, operatorId])
  @@index([contactPhone])
  @@index([operatorId])
  @@index([blockedUntil])
  @@index([tenantId])
}

// Histórico de envio para controle de reenvio
model SendHistory {
  id           Int      @id @default(autoincrement())
  contactPhone String
  campaignId   Int?
  lineId       Int?
  sentAt       DateTime @default(now())
  tenantId     String   @default("default-tenant")
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@index([contactPhone])
  @@index([sentAt])
  @@index([tenantId])
}

// Fila de mensagens quando não há operador online
model MessageQueue {
  id           Int       @id @default(autoincrement())
  contactPhone String
  contactName  String?
  message      String    @db.Text
  /// Optional structured triage from Botify handoff (`data.leadSummary`); validated at ingest.
  leadSummary  Json?
  messageType  String    @default("text")
  mediaUrl     String?
  segment      Int?
  status       String    @default("pending") // pending, processing, sent, failed
  attempts     Int       @default(0)
  errorMessage String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  processedAt  DateTime?
  tenantId     String    @default("default-tenant")
  tenant       Tenant    @relation(fields: [tenantId], references: [id])

  @@index([status])
  @@index([contactPhone])
  @@index([segment])
  @@index([createdAt])
  @@index([tenantId])
}

// Eventos do sistema para acompanhamento e métricas
model SystemEvent {
  id        Int      @id @default(autoincrement())
  type      String // Tipo do evento (operator_connected, line_assigned, message_sent, etc.)
  module    String // Módulo que gerou o evento (websocket, lines, webhooks, etc.)
  data      String?  @db.Text // Dados adicionais em JSON
  userId    Int? // ID do usuário relacionado (se aplicável)
  severity  String   @default("info") // info, warning, error, success
  createdAt DateTime @default(now())

  user     User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  tenantId String @default("default-tenant")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@index([type])
  @@index([module])
  @@index([userId])
  @@index([severity])
  @@index([createdAt])
  @@index([tenantId])
}

// Análises de IA sobre conversas comerciais.
// Esta tabela permite gerar métricas mesmo quando o CRM/tabulação manual está incompleto.
model ConversationAIAnalysis {
  id                Int       @id @default(autoincrement())
  tenantId          String    @default("default-tenant")
  contactPhone      String
  contactName       String?
  segment           Int?
  userId            Int?
  userName          String?
  conversationStart DateTime?
  conversationEnd   DateTime?
  messageCount      Int       @default(0)

  summary                        String   @db.Text
  leadIntent                     String
  opportunityStatus              String
  risk                           String
  mainObjection                  String?
  objections                     String?  @db.Text
  sellerQualityScore             Int      @default(0)
  responseQualityScore           Int      @default(0)
  qualificationScore             Int      @default(0)
  followUpScore                  Int      @default(0)
  firstResponseMinutes           Int?
  hasSellerAbandonment           Boolean  @default(false)
  hasLeadAbandonment             Boolean  @default(false)
  hasQualification               Boolean  @default(false)
  hasSchedulingAttempt           Boolean  @default(false)
  hasProposalOrSimulationAttempt Boolean  @default(false)
  lostOpportunity                Boolean  @default(false)
  nextBestAction                 String   @db.Text
  evidence                       String?  @db.Text
  metrics                        String?  @db.Text
  rawResult                      String?  @db.Text
  modelProvider                  String?
  modelName                      String?
  promptVersion                  String?
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([contactPhone])
  @@index([segment])
  @@index([userId])
  @@index([leadIntent])
  @@index([opportunityStatus])
  @@index([risk])
  @@index([lostOpportunity])
  @@index([createdAt])
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  document  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                  UserTenant[]
  segments               Segment[]
  tabulations            Tabulation[]
  contacts               Contact[]
  campaigns              Campaign[]
  blockLists             BlockList[]
  apps                   App[]
  linesStocks            LinesStock[]
  lineOperators          LineOperator[]
  conversations          Conversation[]
  tags                   Tag[]
  apiLogs                ApiLog[]
  templates              Template[]
  templateMessages       TemplateMessage[]
  controlPanels          ControlPanel[]
  contactRepescagems     ContactRepescagem[]
  sendHistories          SendHistory[]
  messageQueues          MessageQueue[]
  systemEvents           SystemEvent[]
  conversationAIAnalyses ConversationAIAnalysis[]
  aiUsageLogs            AIUsageLog[]
  integrationConnections IntegrationConnection[]
  integrationEvents      IntegrationEvent[]
  integrationEntityLinks IntegrationEntityLink[]
  apiKeys                TenantApiKey[]

  tenantInvitations             TenantInvitation[]
  advertiserCompanies           AdvertiserCompany[]
  adPlatformConnections         AdPlatformConnection[]
  adCampaignAIAnalyses          AdCampaignAIAnalysis[]
  organicPostExperiments        OrganicPostExperiment[]
  organicPostExperimentVariants OrganicPostExperimentVariant[]
  refreshTokens                 RefreshToken[]

  // CRM Imobiliário (Sprint 3)
  crmProperties              CrmProperty[]
  crmUnits                   CrmUnit[]
  crmCommissionConfigs       CrmCommissionConfig[]
  crmClients                 CrmClient[]
  crmLeads                   CrmLead[]
  crmInteractions            CrmInteraction[]
  crmFollowUps               CrmFollowUp[]
  crmProposals               CrmProposal[]
  crmProposalEvents          CrmProposalEvent[]
  crmContracts               CrmContract[]
  crmContractEvents          CrmContractEvent[]
  crmSignatures              CrmSignature[]
  crmPayments                CrmPayment[]
  crmCommissions             CrmCommission[]
  crmDocumentVersions        CrmDocumentVersion[]
  crmDocumentAccessLogs      CrmDocumentAccessLog[]
  crmChangeHistory           CrmChangeHistory[]
  crmNotificationPreferences CrmNotificationPreference[]

  // Botify (ADR-0002) — fonte de verdade de bots/fluxos no Omni
  botifyBots            BotifyBot[]
  botifyFlows           BotifyFlow[]
  botifyConversations   BotifyConversation[]
  botifyMessages        BotifyMessage[]
  botifyMetaAccounts    BotifyMetaAccount[]

  // Sprint Foundation (ADR-0005) — pré-requisitos da Régua de Acionamento
  messageBrokers   MessageBroker[]
  tenantWallet     TenantWallet?
  antiFatigueRule  AntiFatigueRule?
  lineHealthPolicy LineHealthPolicy?
}

model IntegrationConnection {
  id                     String   @id @default(uuid())
  tenantId               String
  provider               String // crm, ads, bot
  // Shared webhook secret used to verify HMAC-SHA256 signatures from
  // the external provider. Stored encrypted at rest (AES-256-GCM via
  // BridgeSecretCipher) and decrypted on demand right before signature
  // verification. NEVER logged. Rotation = create a new row, deprecate
  // the old one. The previous field name (`secretHash`) was misleading:
  // it stored the secret itself, not a hash.
  webhookSecretEncrypted String
  status                 String   @default("active")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  tenant Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  events IntegrationEvent[]

  @@index([tenantId])
  @@index([provider])
  @@index([tenantId, provider])
}

model AIUsageLog {
  id               Int      @id @default(autoincrement())
  tenantId         String   @default("default-tenant")
  conversationId   Int?
  analysisId       Int?
  operationType    String   @default("conversation_analysis")
  modelProvider    String
  modelName        String
  promptVersion    String?
  promptTokens     Int
  completionTokens Int
  estimatedCost    Float
  currency         String   @default("USD")
  status           String   @default("success")
  errorCode        String?
  errorMessage     String?  @db.Text
  createdAt        DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, operationType])
  @@index([tenantId, status])
  @@index([createdAt])
}

model IntegrationEvent {
  id             String    @id @default(uuid())
  tenantId       String
  connectionId   String
  provider       String
  // Idempotency is scoped to (tenant, provider, key). A global @unique
  // was a multi-tenant footgun: two providers — or two tenants on the
  // same provider — could legitimately mint identical keys (UUIDv4
  // collision is rare, but hash-of-body collisions across tenants
  // sharing a similar template are not). Cross-tenant collisions are
  // expected and must NOT silently swallow the event.
  idempotencyKey String
  signature      String?
  status         String    @default("received")
  errorMessage   String?   @db.Text
  payload        Json
  createdAt      DateTime  @default(now())
  processedAt    DateTime?

  tenant     Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connection IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider, idempotencyKey])
  @@index([tenantId])
  @@index([tenantId, provider])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([connectionId])
}

model IntegrationEntityLink {
  id         String   @id @default(uuid())
  tenantId   String
  provider   String
  externalId String
  entityType String
  entityId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider, externalId, entityType])
  @@index([tenantId])
  @@index([tenantId, provider])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, provider, externalId])
}

model UserTenant {
  id       String @id @default(uuid())
  userId   Int
  tenantId String @default("default-tenant")
  role     Role

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
}

// Versioned price table used by InsightAI and other AI operations to
// compute cost without hard-coded constants. Lookup by (provider, model,
// at <= effectiveUntil OR effectiveUntil = null). Prices are per 1k
// tokens. Currency tracked alongside the rate.
model ModelPricing {
  id             Int       @id @default(autoincrement())
  modelProvider  String
  modelName      String
  inputPer1k     Float
  outputPer1k    Float
  currency       String    @default("USD")
  effectiveFrom  DateTime  @default(now())
  effectiveUntil DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([modelProvider, modelName])
  @@index([modelProvider, modelName, effectiveFrom])
  @@index([modelProvider, modelName, effectiveUntil])
}

// Server-to-server credential. Stored as sha256(secret), never as plaintext.
// Resolved by ApiKeyGuard to obtain the tenant context for non-JWT callers
// (massive CPC dispatch, external integrations, scripts, etc.).
model TenantApiKey {
  id          String    @id @default(uuid())
  tenantId    String
  hashedKey   String    @unique
  prefix      String // first ~8 chars of the plaintext for human identification only
  label       String
  scopes      Json? // optional fine-grained scope list (future use)
  createdById Int?
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  expiresAt   DateTime?

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?  @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, revokedAt])
  @@index([prefix])
}

// ---------------------------------------------------------------------------
// Smart Ad Automator (SAA) — Sprint 2.3
// ---------------------------------------------------------------------------
// Migrated from the Supabase schema of the SAA standalone project. Maps:
//   agencies              -> Tenant (1:1, no separate Agency entity)
//   agency_members        -> UserTenant
//   agency_invitations    -> TenantInvitation
//   companies             -> AdvertiserCompany
//   client_company_access -> AdvertiserCompanyAccess
//   platform_configurations + meta_configurations -> AdPlatformConnection
//   ai_campaign_analyses  -> AdCampaignAIAnalysis
//   organic_post_experiments / variants -> OrganicPostExperiment(+Variant)
//   audit_logs            -> reuses SystemEvent
// OAuth tokens (access_token / refresh_token) are stored ENCRYPTED at rest
// using AES-256-GCM via BridgeSecretCipher (Sprint 1.3). Plaintext tokens
// MUST never be persisted.

// Invitation to join a Tenant (agency) with a given Role. Replaces
// Supabase's `agency_invitations`. The `token` is a single-use random
// secret embedded in the invite URL. Acceptance creates a UserTenant
// row and sets `acceptedAt`/`acceptedById`.
model TenantInvitation {
  id           String    @id @default(uuid())
  tenantId     String
  email        String
  role         Role
  token        String    @unique
  invitedById  Int?
  acceptedById Int?
  acceptedAt   DateTime?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy  User?  @relation("TenantInvitationInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  acceptedBy User?  @relation("TenantInvitationAcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, email])
  @@index([token])
  @@index([expiresAt])
}

// Advertiser business managed inside a tenant (agency). Holds non-token
// metadata about the end advertiser; OAuth credentials live in
// AdPlatformConnection. Distinct from CRM Lead/Contact: an AdvertiserCompany
// is the *paying* end-client of the agency, not a sales prospect.
model AdvertiserCompany {
  id              String    @id @default(uuid())
  tenantId        String
  name            String
  businessName    String
  metaBusinessId  String?
  currency        String    @default("BRL")
  timezone        String    @default("America/Sao_Paulo")
  status          String    @default("pending")
  totalSpent      Float     @default(0)
  activeCampaigns Int       @default(0)
  lastSyncAt      DateTime?
  createdById     Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("AdvertiserCompanyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  accesses            AdvertiserCompanyAccess[]
  platformConnections AdPlatformConnection[]
  campaignAIAnalyses  AdCampaignAIAnalysis[]
  organicExperiments  OrganicPostExperiment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, name])
}

// End-client visibility: which user inside a tenant can see which
// advertiser companies. Used to scope ClientLogin/dashboard reads.
model AdvertiserCompanyAccess {
  id                  String   @id @default(uuid())
  tenantId            String
  userId              Int
  advertiserCompanyId String
  createdAt           DateTime @default(now())

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  advertiserCompany AdvertiserCompany @relation(fields: [advertiserCompanyId], references: [id], onDelete: Cascade)

  @@unique([userId, advertiserCompanyId])
  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([advertiserCompanyId])
}

// OAuth credentials and metadata for an external ad platform (Meta /
// Google Ads / TikTok Ads), scoped to one AdvertiserCompany. accessToken
// and refreshToken are NEVER stored in plaintext — both are encrypted with
// AES-256-GCM (BridgeSecretCipher) using BRIDGE_SECRET_KEY. Tokens are
// decrypted on demand right before outbound calls and never logged.
// `extra` holds provider-specific fields (e.g. Meta `app_id`, `app_secret`,
// `meta_business_id`, Google `customer_id`, TikTok `advertiser_id`).
// Unique per (advertiserCompanyId, platform) — one connection per platform.
model AdPlatformConnection {
  id                    String     @id @default(uuid())
  tenantId              String
  advertiserCompanyId   String
  platform              AdPlatform
  accountId             String?
  accessTokenEncrypted  String?    @db.Text
  refreshTokenEncrypted String?    @db.Text
  tokenExpiresAt        DateTime?
  isActive              Boolean    @default(true)
  extra                 Json?
  createdById           Int?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  advertiserCompany AdvertiserCompany @relation(fields: [advertiserCompanyId], references: [id], onDelete: Cascade)
  createdBy         User?             @relation("AdPlatformConnectionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([advertiserCompanyId, platform])
  @@index([tenantId])
  @@index([tenantId, platform])
  @@index([tokenExpiresAt])
}

// AI analysis result of a single ad campaign on an external platform.
// `analysis` is the structured LLM output (recommendations, anomalies,
// insights). Costs are tracked separately via AIUsageLog with
// operationType='ad_campaign_analysis'.
model AdCampaignAIAnalysis {
  id                  String     @id @default(uuid())
  tenantId            String
  advertiserCompanyId String
  platform            AdPlatform
  campaignId          String
  campaignName        String?
  analysis            Json
  modelProvider       String?
  modelName           String?
  promptVersion       String?
  generatedById       Int?
  createdAt           DateTime   @default(now())

  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  advertiserCompany AdvertiserCompany @relation(fields: [advertiserCompanyId], references: [id], onDelete: Cascade)
  generatedBy       User?             @relation("AdCampaignAIAnalysisGeneratedBy", fields: [generatedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, platform])
  @@index([tenantId, campaignId])
  @@index([tenantId, advertiserCompanyId, createdAt])
  @@index([createdAt])
}

// A/B experiment on organic social posts (Meta/Instagram/TikTok).
// `mode = retroactive|manual|publish`, `status = draft|running|completed|cancelled`.
// `winningMetric` chooses the comparison axis (engagement_rate, reach, etc.).
// `aiSummary` holds an optional LLM-generated narrative of the result.
model OrganicPostExperiment {
  id                  String     @id @default(uuid())
  tenantId            String
  advertiserCompanyId String
  platform            AdPlatform @default(meta)
  accountId           String?
  name                String
  hypothesis          String?    @db.Text
  mode                String // retroactive | manual | publish
  winningMetric       String     @default("engagement_rate")
  minSampleReach      Int        @default(0)
  durationDays        Int        @default(7)
  status              String     @default("draft") // draft|running|completed|cancelled
  startedAt           DateTime?
  endsAt              DateTime?
  winnerVariantId     String?
  aiSummary           Json?
  createdById         Int?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  advertiserCompany AdvertiserCompany @relation(fields: [advertiserCompanyId], references: [id], onDelete: Cascade)
  createdBy         User?             @relation("OrganicPostExperimentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  variants OrganicPostExperimentVariant[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, advertiserCompanyId])
  @@index([tenantId, platform])
}

// A single arm of an OrganicPostExperiment. `metricsSnapshot` captures the
// metric values at evaluation time so a re-run does not silently mutate
// historical comparisons.
model OrganicPostExperimentVariant {
  id              String    @id @default(uuid())
  tenantId        String
  experimentId    String
  label           String
  note            String?   @db.Text
  postId          String?
  scheduledFor    DateTime?
  caption         String?   @db.Text
  mediaUrl        String?
  postType        String?
  platform        String?
  metricsSnapshot Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant     Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  experiment OrganicPostExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([experimentId])
  @@index([tenantId, experimentId])
}

// ---------------------------------------------------------------------------
// Auth refresh tokens (Sprint 2.4)
// ---------------------------------------------------------------------------
// Refresh token rotativo, persistido como SHA-256 hex do segredo bruto
// (`tokenHash`). O segredo cru existe APENAS no HttpOnly cookie do cliente; o
// banco guarda só o hash, então um leak de DB não permite reuso. Cada
// /auth/refresh:
//   1. Procura por tokenHash do cookie.
//   2. Falha se já foi revogado (revokedAt != null) ou expirou.
//   3. Cria novo RefreshToken, seta `replacedById` no antigo e revoga o
//      antigo (`revokedAt = now()`). Detecção de reuse: se o cliente
//      apresenta um token que já está `revokedAt != null` mas tem
//      `replacedById`, é um possível roubo — revogamos TODA a cadeia do
//      usuário e auditamos (AUTH_REFRESH_REUSE_DETECTED).
//
// `tenantId` é o tenant ativo no momento da emissão. Em produção a
// JwtStrategy exige UserTenant válido — mesmo que o refresh devolva access
// para outro tenant, a Strategy bloqueia o request.
model RefreshToken {
  id          String    @id @default(uuid())
  tenantId    String
  userId      Int
  tokenHash   String    @unique
  userAgent   String?
  ipAddress   String?
  expiresAt   DateTime
  revokedAt   DateTime?
  successorId String?   @unique
  createdAt   DateTime  @default(now())

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  successor   RefreshToken? @relation("RefreshTokenRotation", fields: [successorId], references: [id], onDelete: SetNull)
  predecessor RefreshToken? @relation("RefreshTokenRotation")

  @@index([tenantId])
  @@index([userId])
  @@index([tenantId, userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

// ---------------------------------------------------------------------------
// CRM Imobiliário (Sprint 3)
// ---------------------------------------------------------------------------
// Modelos para gestão de empreendimentos imobiliários, leads, propostas,
// contratos, assinaturas (Clicksign), financeiro (parcelas, comissões) e
// auditoria. Todo modelo carrega `tenantId` com índice composto para isolar
// queries — não há nenhuma view global. PKs em uuid para encaixar no padrão
// do Supabase original sem reescrever IDs em referências cruzadas.
// ---------------------------------------------------------------------------

// Empreendimento imobiliário (lote, prédio, condomínio).
model CrmProperty {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  address     String
  city        String
  developer   String?
  imageUrl    String?
  towers      Json     @default("[]")
  documents   Json     @default("[]")
  createdById Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("CrmPropertyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  units            CrmUnit[]
  commissionConfig CrmCommissionConfig?
  leads            CrmLead[]
  proposals        CrmProposal[]
  contracts        CrmContract[]
  payments         CrmPayment[]
  commissions      CrmCommission[]

  @@index([tenantId])
  @@index([tenantId, name])
}

// Unidade dentro de um Property. `status` evolui available → reserved → sold;
// `clientId` é guardado direto (sem FK forte porque é populado em momentos
// distintos do ciclo — reserva temporária, contrato assinado, etc).
model CrmUnit {
  id                String        @id @default(uuid())
  tenantId          String
  propertyId        String
  number            String
  tower             String?
  typology          String?
  floor             Int?
  area              Decimal?      @db.Decimal(12, 2)
  price             Decimal?      @db.Decimal(14, 2)
  status            CrmUnitStatus @default(available)
  observations      String?       @db.Text
  clientId          String?
  reservedAt        DateTime?
  reservationExpiry DateTime?
  proposalId        String?
  contractId        String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property CrmProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  proposals   CrmProposal[]
  contracts   CrmContract[]
  payments    CrmPayment[]
  commissions CrmCommission[]

  @@unique([tenantId, propertyId, number])
  @@index([tenantId])
  @@index([tenantId, propertyId])
  @@index([tenantId, status])
}

// Percentual de comissão por empreendimento. `propertyId` é PK no Supabase
// original; aqui mantemos uuid próprio mas exigimos unique por property.
model CrmCommissionConfig {
  id                String   @id @default(uuid())
  tenantId          String
  propertyId        String   @unique
  commissionPercent Decimal  @default(5) @db.Decimal(5, 2)
  updatedById       Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property CrmProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// Cliente comprador. PII (cpf_cnpj, phone, email, income) protegida por
// JwtAuthGuard + tenant scoping. Serviços nunca devem retornar `cpfCnpj` em
// listas; só no detalhe e mediante audit em CrmDocumentAccessLog quando o
// acesso for crítico.
model CrmClient {
  id        String          @id @default(uuid())
  tenantId  String
  name      String
  cpfCnpj   String?
  phone     String?
  email     String?
  income    Decimal?        @db.Decimal(14, 2)
  score     CrmClientScore?
  notes     String?         @db.Text
  brokerId  Int?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  broker User?  @relation("CrmClientBroker", fields: [brokerId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, brokerId])
  @@index([tenantId, cpfCnpj])
}

// Lead no pipeline. `brokerName` é cache denormalizado (snapshot da época
// da atribuição). Tabela realtime — vide CrmGateway (Bloco E).
model CrmLead {
  id               String       @id @default(uuid())
  tenantId         String
  name             String
  email            String?
  phone            String?
  source           String?
  stage            CrmLeadStage @default(new)
  brokerId         Int?
  brokerName       String?
  propertyId       String?
  clientId         String?
  propertyInterest String?
  estimatedValue   Decimal?     @db.Decimal(14, 2)
  notes            String?      @db.Text
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  broker   User?        @relation("CrmLeadBroker", fields: [brokerId], references: [id], onDelete: SetNull)
  property CrmProperty? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  interactions CrmInteraction[]
  followUps    CrmFollowUp[]

  @@index([tenantId])
  @@index([tenantId, stage])
  @@index([tenantId, brokerId])
  @@index([tenantId, clientId])
}

// Interação registrada no lead (call/email/whatsapp/meeting/note/visit).
model CrmInteraction {
  id          String             @id @default(uuid())
  tenantId    String
  leadId      String
  type        CrmInteractionType
  content     String?            @db.Text
  createdById Int?
  createdAt   DateTime           @default(now())

  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead      CrmLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("CrmInteractionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, leadId])
}

// Tarefa de follow-up associada ao lead.
model CrmFollowUp {
  id          String    @id @default(uuid())
  tenantId    String
  leadId      String
  scheduledAt DateTime
  status      String    @default("pending")
  title       String?
  notes       String?   @db.Text
  completedAt DateTime?
  createdById Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead      CrmLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("CrmFollowUpCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, leadId])
  @@index([tenantId, status])
  @@index([tenantId, scheduledAt])
}

// Proposta comercial gerada para uma unidade. `paymentCondition` é JSON livre
// com `{ installments: [{amount, dueDate, type}], ... }`. Snapshot dos nomes
// (`propertyName`, `unitNumber`, `clientName`, `brokerName`) é mantido para
// quando a entidade original sofrer rename/exclusão.
model CrmProposal {
  id               String            @id @default(uuid())
  tenantId         String
  propertyId       String
  unitId           String
  clientId         String
  brokerId         Int
  propertyName     String
  unitNumber       String
  clientName       String
  brokerName       String?
  originalPrice    Decimal?          @db.Decimal(14, 2)
  discount         Decimal?          @db.Decimal(14, 2)
  discountPercent  Decimal?          @db.Decimal(6, 2)
  finalPrice       Decimal?          @db.Decimal(14, 2)
  paymentCondition Json              @default("{}")
  status           CrmProposalStatus @default(draft)
  validUntil       DateTime?
  pdfUrl           String?
  sourcePdfUrl     String?
  notes            String?           @db.Text
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  broker   User        @relation("CrmProposalBroker", fields: [brokerId], references: [id], onDelete: Restrict)
  property CrmProperty @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  unit     CrmUnit     @relation(fields: [unitId], references: [id], onDelete: Restrict)

  events    CrmProposalEvent[]
  contracts CrmContract[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, brokerId])
  @@index([tenantId, unitId])
  @@index([tenantId, clientId])
}

// Histórico imutável de mudanças de status / eventos da proposta.
model CrmProposalEvent {
  id          String   @id @default(uuid())
  tenantId    String
  proposalId  String
  eventType   String
  fromStatus  String?
  toStatus    String?
  message     String?  @db.Text
  createdById Int?
  createdAt   DateTime @default(now())

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  proposal CrmProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, proposalId])
}

// Contrato gerado a partir de uma proposta aceita. `signatures` JSONB é
// snapshot sincronizado pela aplicação a partir da tabela CrmSignature
// (signatures-sync no app layer). Status → 'signed' dispara o trigger
// `crm_generate_financials_on_signed` que insere CrmPayment + CrmCommission.
model CrmContract {
  id                  String            @id @default(uuid())
  tenantId            String
  proposalId          String?
  propertyId          String
  unitId              String
  clientId            String
  brokerId            Int
  propertyName        String
  unitNumber          String
  clientName          String
  clientCpfCnpj       String?
  brokerName          String?
  finalPrice          Decimal?          @db.Decimal(14, 2)
  paymentCondition    Json              @default("{}")
  status              CrmContractStatus @default(draft)
  signatures          Json              @default("[]")
  pdfUrl              String?
  sourcePdfUrl        String?
  notes               String?           @db.Text
  externalEnvelopeId  String?
  externalProvider    String?
  externalEnvelopeUrl String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  broker   User         @relation("CrmContractBroker", fields: [brokerId], references: [id], onDelete: Restrict)
  proposal CrmProposal? @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  property CrmProperty  @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  unit     CrmUnit      @relation(fields: [unitId], references: [id], onDelete: Restrict)

  events         CrmContractEvent[]
  signaturesList CrmSignature[]
  payments       CrmPayment[]
  commissions    CrmCommission[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, brokerId])
  @@index([tenantId, unitId])
  @@index([externalEnvelopeId])
}

// Histórico imutável de eventos do contrato.
model CrmContractEvent {
  id          String   @id @default(uuid())
  tenantId    String
  contractId  String
  eventType   String
  fromStatus  String?
  toStatus    String?
  message     String?  @db.Text
  createdById Int?
  createdAt   DateTime @default(now())

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contract CrmContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, contractId])
}

// Assinaturas individuais (signers) de um contrato Clicksign. `token` é
// usado para webhook callback matching; `signatureHash` é o hash do PDF
// assinado retornado pelo provider.
model CrmSignature {
  id            String    @id @default(uuid())
  tenantId      String
  contractId    String
  role          String
  signerName    String?
  signerEmail   String?
  status        String    @default("pending")
  token         String    @default(uuid())
  signedAt      DateTime?
  ipAddress     String?
  signatureHash String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contract CrmContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, role])
  @@index([tenantId])
  @@index([tenantId, contractId])
  @@index([token])
}

// Parcela financeira. Gerada por trigger SQL on-signed lendo
// `paymentCondition.installments` do contrato (vide migration).
model CrmPayment {
  id                String           @id @default(uuid())
  tenantId          String
  contractId        String
  propertyId        String
  unitId            String
  clientId          String
  propertyName      String
  unitNumber        String
  clientName        String
  type              CrmPaymentType
  installmentNumber Int?
  amount            Decimal?         @db.Decimal(14, 2)
  dueDate           DateTime?
  paidAt            DateTime?
  status            CrmPaymentStatus @default(pending)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contract CrmContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  property CrmProperty @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  unit     CrmUnit     @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@unique([tenantId, contractId, installmentNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, contractId])
  @@index([tenantId, dueDate])
}

// Comissão devida ao corretor. Gerada por trigger SQL on-signed.
model CrmCommission {
  id                String              @id @default(uuid())
  tenantId          String
  contractId        String
  propertyId        String
  unitId            String
  brokerId          Int
  propertyName      String
  unitNumber        String
  brokerName        String?
  salePrice         Decimal?            @db.Decimal(14, 2)
  commissionPercent Decimal?            @db.Decimal(6, 2)
  commissionValue   Decimal?            @db.Decimal(14, 2)
  status            CrmCommissionStatus @default(pending)
  paidAt            DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contract CrmContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  property CrmProperty @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  unit     CrmUnit     @relation(fields: [unitId], references: [id], onDelete: Restrict)
  broker   User        @relation("CrmCommissionBroker", fields: [brokerId], references: [id], onDelete: Restrict)

  @@unique([tenantId, contractId, brokerId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, contractId])
  @@index([tenantId, brokerId])
}

// Versionamento de PDFs de proposal/contract. `parentType` discrimina entre
// proposta e contrato (o `parentId` aponta para a row correspondente).
model CrmDocumentVersion {
  id           String                   @id @default(uuid())
  tenantId     String
  parentType   CrmDocumentParentType
  parentId     String
  pdfUrl       String
  fileName     String?
  action       CrmDocumentVersionAction
  uploadedById Int?
  uploaderName String?
  createdAt    DateTime                 @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, parentType, parentId])
}

// Log de acesso a documentos (LGPD). Toda visualização/download é registrada.
model CrmDocumentAccessLog {
  id         String                  @id @default(uuid())
  tenantId   String
  parentType CrmDocumentParentType
  parentId   String
  pdfUrl     String
  action     CrmDocumentAccessAction
  userId     Int?
  userName   String?
  createdAt  DateTime                @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, parentType, parentId])
  @@index([tenantId, userId])
}

// Audit log dedicado do CRM (campos sensíveis: stage, broker_id, price,
// status etc.). Não substitui SystemEvent — convive: SystemEvent guarda
// eventos de produto (LeadCreated, ContractSigned…); CrmChangeHistory
// guarda diff em campo específico.
model CrmChangeHistory {
  id         String   @id @default(uuid())
  tenantId   String
  entityType String
  entityId   String
  field      String
  oldValue   String?  @db.Text
  newValue   String?  @db.Text
  userId     Int?
  userName   String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, entityType, entityId])
}

// Preferências de notificação CRM por usuário, escopadas ao tenant
// (operador pode ter prefs distintas em tenants diferentes).
model CrmNotificationPreference {
  id                       String   @id @default(uuid())
  tenantId                 String
  userId                   Int
  proposalSent             Boolean  @default(true)
  contractPendingSignature Boolean  @default(true)
  paymentDueSoon           Boolean  @default(true)
  paymentOverdue           Boolean  @default(true)
  commissionPaid           Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
}

/// Bot lógico Botify (tenant-scoped). `externalSourceId` = id estável WP para import idempotente.
enum BotifyMessageRole {
  user
  assistant
  system
}

/// Conta Meta/Evolution tenant-scoped — fonte única para Chips + routing de webhooks (G7-D4).
model BotifyMetaAccount {
  id                 String   @id @default(uuid())
  tenantId           String
  name               String
  businessManagerId  String?
  metaWabaAccountId  String?
  accessTokenEnc     String?
  webhookCallbackUrl String?
  webhookVerifyToken String?
  webhookEvents      Json?
  phoneNumberIds     Json?
  defaultBotId       String?
  defaultFlowId      String?
  evolutionInstance  String?
  evolutionApiKeyEnc String?
  isActive           Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  defaultBot BotifyBot?  @relation("MetaAccountDefaultBot", fields: [defaultBotId], references: [id], onDelete: SetNull)
  linkedBots BotifyBot[] @relation("BotLinkedMetaAccount")

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, metaWabaAccountId])
  @@index([tenantId, businessManagerId])
  @@index([tenantId, evolutionInstance])
}

model BotifyBot {
  id               String   @id @default(uuid())
  tenantId         String
  name             String
  description      String?
  externalSourceId String?
  isActive         Boolean  @default(true)
  /// Conta Meta/Evolution canónica (Chips Omni). Credenciais vivem em BotifyMetaAccount.
  metaAccountId    String?
  /// Overrides por bot: phoneNumberId, defaultFlowId (legado: JSON completo até migração).
  channelConfig    Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  metaAccount   BotifyMetaAccount?   @relation("BotLinkedMetaAccount", fields: [metaAccountId], references: [id], onDelete: SetNull)
  metaAccountsDefault BotifyMetaAccount[] @relation("MetaAccountDefaultBot")
  flows         BotifyFlow[]
  conversations BotifyConversation[]

  @@index([tenantId])
  @@index([tenantId, metaAccountId])
  @@unique([tenantId, externalSourceId])
}

/// Fluxo Botify: rascunho vs publicado em JSON (`BotifyFlowGraph` / contrato shared-types).
model BotifyFlow {
  id               String    @id @default(uuid())
  tenantId         String
  botId            String
  name             String
  triggerKeyword   String?
  externalSourceId String?
  draftGraph       Json?
  publishedGraph   Json?
  publishedAt      DateTime?
  publishedVersion Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bot    BotifyBot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, botId])
  @@unique([tenantId, externalSourceId])
}

/// Conversa Botify (triagem automática) — distinta de `Conversation` operacional do inbox.
model BotifyConversation {
  id           String   @id @default(uuid())
  tenantId     String
  botId        String
  contactPhone String
  contactName  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bot      BotifyBot       @relation(fields: [botId], references: [id], onDelete: Cascade)
  messages BotifyMessage[]

  @@unique([tenantId, botId, contactPhone])
  @@index([tenantId])
  @@index([tenantId, botId])
  @@index([tenantId, updatedAt])
}

model BotifyMessage {
  id             String            @id @default(uuid())
  tenantId       String
  conversationId String
  role           BotifyMessageRole
  content        String            @db.Text
  metadata       Json?
  createdAt      DateTime          @default(now())

  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation BotifyConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([tenantId, conversationId])
  @@index([conversationId, createdAt])
}

// Sprint Quick-wins — Line-health policy
// Política por tenant para alertas e ações automáticas sobre saúde da linha
// WhatsApp. Não calcula score — usa `line-reputation` existente. Sugere ou
// aplica (`throttle` / `block`) por nível.
enum LineHealthAction {
  none // só alerta
  throttle
  block
}

model LineHealthPolicy {
  id                       String           @id @default(cuid())
  tenantId                 String           @unique
  alertHoursMedium         Int              @default(6) // alerta quando linha está em status MEDIUM/FLAGGED há > N horas
  alertHoursLow            Int              @default(2) // alerta quando linha está em status LOW/RESTRICTED há > N horas
  autoActionOnCritical     LineHealthAction @default(none)
  autoActionOnHigh         LineHealthAction @default(none)
  suggestRotation          Boolean          @default(true)
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// Sprint Foundation — F3: AntiFatigueRule
// Janela mínima entre sends para o mesmo contato (anti-spam). Per-tenant
// (1 regra global). Pré-requisito de execução da Régua (ADR-0005).
enum AntiFatigueAppliesTo {
  phone
  document
  both
}

model AntiFatigueRule {
  id                   String               @id @default(cuid())
  tenantId             String               @unique
  enabled              Boolean              @default(true)
  windowHours          Int                  @default(24)
  appliesTo            AntiFatigueAppliesTo @default(both)
  allowBypassForUrgent Boolean              @default(false)
  businessHoursStart   String? // 'HH:MM' (UTC) — vazio = sem restrição
  businessHoursEnd     String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model AntiFatigueDedupeLog {
  id         String   @id @default(cuid())
  tenantId   String
  contactKey String // phone E.164 ou documento (dígitos)
  channel    String
  blockedAt  DateTime @default(now())
  refType    String?
  refId      String?

  @@index([tenantId])
  @@index([tenantId, contactKey, blockedAt])
  @@index([tenantId, blockedAt])
}

// Sprint Foundation — F2: TenantWallet
// Orçamento por tenant com sub-budgets por canal, débito real-time
// durante journey runs, histórico de transações. Hard ou soft block
// configurável. Pré-requisito da Régua de Acionamento (ADR-0005).
enum WalletResetCycle {
  monthly
  weekly
}

enum WalletGuardMode {
  hard_block
  soft_block
}

enum WalletTransactionType {
  debit
  credit
  refund
}

model TenantWallet {
  id               String           @id @default(cuid())
  tenantId         String           @unique
  totalBudgetCents Int              @default(0)
  usedBudgetCents  Int              @default(0)
  resetCycle       WalletResetCycle @default(monthly)
  resetAt          DateTime?
  guardMode        WalletGuardMode  @default(soft_block)
  realtimeDebit    Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channelCosts WalletChannelCost[]
  transactions WalletTransaction[]

  @@index([tenantId])
}

model WalletChannelCost {
  id        String @id @default(cuid())
  walletId  String
  channel   String
  costCents Int    @default(0)

  wallet TenantWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([walletId, channel])
}

model WalletTransaction {
  id          String                @id @default(cuid())
  tenantId    String
  walletId    String
  type        WalletTransactionType
  channel     String?
  amountCents Int
  refType     String?
  refId       String?
  metadata    Json?
  createdAt   DateTime              @default(now())

  wallet TenantWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([walletId, type])
}

// Sprint Foundation — F1: MessageBroker
// Provedores de canal outbound (SMS/Email/RCS). WhatsApp segue em `lines/`
// (Meta Cloud). Cada tenant configura seus brokers; ADR-0005 documenta o
// papel desta tabela como pré-requisito de execução da Régua.
enum MessageBrokerChannel {
  sms
  email
  rcs
}

enum MessageBrokerStatus {
  connected
  attention
  disconnected
}

model MessageBroker {
  id                     String               @id @default(cuid())
  tenantId               String
  channel                MessageBrokerChannel
  vendor                 String
  label                  String
  status                 MessageBrokerStatus  @default(connected)
  autoDisableOnBounce    Boolean              @default(true)
  monthlyCostCents       Int                  @default(0)
  fallbackBrokerId       String?
  // statusMap: map vendor-specific → canônico {sent, invalid, duplicated, spam, bounced}
  statusMap              Json
  // Credenciais cifradas via BridgeSecretCipher (AES-256-GCM, v1.<iv>.<tag>.<ct>)
  apiKeyEncrypted        String?
  apiSecretEncrypted     String?
  webhookSecretEncrypted String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  createdById            Int?

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fallbackBroker MessageBroker?  @relation("BrokerFallback", fields: [fallbackBrokerId], references: [id], onDelete: SetNull)
  fallbackOf     MessageBroker[] @relation("BrokerFallback")

  @@index([tenantId])
  @@index([tenantId, channel])
  @@index([tenantId, status])
}
