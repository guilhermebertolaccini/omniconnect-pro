# =============================================================================
# OmniconnectPRO — Environment variables example
# Copy to .env and fill values. NEVER commit .env.
# =============================================================================

# ---- Backend (omniconnect-backend) ----

# Database
DATABASE_URL="postgresql://dev:dev@localhost:5432/omniconnect?schema=public"

# Redis (BullMQ + cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0

# Auth
JWT_SECRET=change_me_in_production_minimum_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# Logging
LOG_LEVEL=debug                  # debug | info | warn | error

# ---- AI / InsightAI ----

OPENAI_API_KEY=                  # leave empty to use heuristic fallback
OPENAI_MODEL=gpt-4o-mini

# Cost tracking pricing (override defaults if needed)
# AI_PRICING_OVERRIDE=

# ---- WhatsApp Cloud API ----

WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=

# ---- Meta Business ----

META_APP_ID=
META_APP_SECRET=

# ---- Bridges (per integration secrets) ----

CRM_BRIDGE_SECRET=               # HMAC para assinar payload OmniConnect → CRM
BOTIFY_BRIDGE_SECRET=
ADS_BRIDGE_SECRET=

# ---- Supabase (CRM e SAA — apps frontend) ----

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---- Frontends ----

VITE_API_URL=http://localhost:3000
VITE_APP_NAME=OmniconnectPRO

# ---- Observability (futuro) ----

# SENTRY_DSN=
# OTEL_EXPORTER_OTLP_ENDPOINT=
